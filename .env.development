# 本地开发 - 默认开启前端 Mock

# 是否开启前端 Mock.js 拦截
VITE_USE_MOCK = false
# 后端 API 地址 (当 VITE_USE_MOCK 为 false 时生效)
# 统一前缀，确保所有请求都以 /api 开头，这样才能触发 vite 的 proxy
VITE_API_BASE_URL = /api

#本地开发（想看假数据）	npm run dev	.env.development (设为 true)	页面有数据，后端不需要启动。
#本地联调（连 Python 后端）	npm run dev	.env.development (设为 false)	(重启服务后) 页面数据来自后端 Python。
#项目打包（准备部署上线）	npm run build	.env.production	打包出的 dist 文件夹里，Mock 逻辑被彻底剔除。